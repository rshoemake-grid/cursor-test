# Copy to .env and fill in values. NEVER commit .env - it is in .gitignore.
# Required keys are loaded from environment variables at runtime.

# === REQUIRED IN PRODUCTION ===
# SECRET_KEY - JWT signing (required when ENVIRONMENT=production)
# SECRET_KEY=your-secure-random-string-min-32-chars

# REFRESH_TOKEN_SECRET_KEY - Optional, defaults to SECRET_KEY
# REFRESH_TOKEN_SECRET_KEY=your-refresh-secret

# === OPTIONAL - LLM API Keys (fallback if not in Settings) ===
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# GOOGLE_API_KEY=...  # Alternative to GEMINI_API_KEY

# === OPTIONAL - Local file system security ===
# LOCAL_FILE_BASE_PATH - Restrict file access to this directory (recommended in production)
# LOCAL_FILE_BASE_PATH=/data/workflows

# === OTHER ===
# ENVIRONMENT=development  # or production
# DATABASE_URL=sqlite+aiosqlite:///./workflows.db
# Relative SQLite paths are resolved to the repo root (same DB no matter which folder you start uvicorn from).

# Optional (development only): create this user if missing and reset password on every backend startup.
# Copy these lines into .env for a fixed dev login (e.g. rshoemake / abcd1234) after a fresh DB.
# DEV_BOOTSTRAP_USERNAME=rshoemake
# DEV_BOOTSTRAP_PASSWORD=abcd1234
# DEV_BOOTSTRAP_EMAIL=rshoemake@example.com   # optional; default is <username>@dev-bootstrap.local
