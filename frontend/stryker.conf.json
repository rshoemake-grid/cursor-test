{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "reporters": ["html", "clear-text", "progress"],
  "testRunner": "jest",
  "coverageAnalysis": "perTest",
  "ignoreStatic": true,
  "dryRunTimeoutMinutes": 120,
  "concurrency": 8,
  "timeoutMS": 600000,
  "maxTestRunnerReuse": 50,
  "plugins": ["@stryker-mutator/jest-runner"],
  "mutate": [
    "src/utils/**/*.{js,jsx}",
    "src/types/**/*.{js,jsx}",
    "src/hooks/**/*.{js,jsx}",
    "src/components/ExecutionStatusBadge.jsx",
    "src/components/LogLevelBadge.jsx",
    "src/components/editors/**/*.{js,jsx}",
    "!src/**/*.test.{js,jsx}",
    "!src/**/*.test.setup.js",
    "!src/**/*.spec.{js,jsx}",
    "!src/test/**",
    "!src/utils/errorFactory.js",
    "!src/hooks/utils/safeCallbacks.js",
    "!src/hooks/utils/safeRefs.js"
  ],
  "checkers": [],
  "thresholds": {
    "high": 80,
    "low": 70,
    "break": 60
  },
  "jest": {
    "configFile": "./jest.config.cjs",
    "enableFindRelatedTests": false,
    "projectType": "custom"
  },
  "logLevel": "info",
  "fileLogLevel": "trace"
}
