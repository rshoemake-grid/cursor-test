{
  "name": "workflow-builder-ui",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.24.0"
  },
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "start": "react-scripts start",
    "start:dev": "BROWSER=none HOST=127.0.0.1 PORT=3000 react-scripts start",
    "build": "DISABLE_ESLINT_PLUGIN=true react-scripts build",
    "build:check": "pnpm run lint && DISABLE_ESLINT_PLUGIN=true react-scripts build",
    "build:server": "rm -rf server/public && pnpm run build && cp -r ./build server/public",
    "test": "jest --watchAll=false",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:workers-8": "jest --maxWorkers=8",
    "test:mutation": "STRYKER_RUNNING=1 stryker run --dryRunTimeoutMinutes 120",
    "test:quick": "./scripts/test-quick.sh",
    "test:full": "./scripts/test-full.sh",
    "test:watch-script": "./scripts/test-watch.sh",
    "lint": "eslint \"src/**/*.{js,jsx,mjs}\" --ignore-pattern \"**/*.test.js\" --ignore-pattern \"**/*.test.jsx\" --ignore-pattern \"**/*.test.setup.js\" --ignore-pattern \"**/*.test.shared.jsx\" --ignore-pattern \"**/test/**\" --report-unused-disable-directives --max-warnings 400",
    "lint:fix": "eslint \"src/**/*.{js,jsx,mjs}\" --ignore-pattern \"**/*.test.js\" --ignore-pattern \"**/*.test.jsx\" --ignore-pattern \"**/*.test.setup.js\" --ignore-pattern \"**/*.test.shared.jsx\" --ignore-pattern \"**/test/**\" --fix",
    "prepare": "sh -c 'r=$(git rev-parse --show-toplevel 2>/dev/null); [ -n \"$r\" ] && (cd \"$r\" && husky) || true'",
    "postinstall": "sh -c 'if [ -d .hooks ]; then for f in .hooks/*; do [ -f \"$f\" ] && chmod +x \"$f\" || true; done; fi'"
  },
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@fontsource/roboto": "^5.1.0",
    "@mui/icons-material": "^6.1.7",
    "@mui/material": "^6.1.6",
    "@reduxjs/toolkit": "^2.3.0",
    "@xyflow/react": "^12.0.0",
    "csv-parse": "^5.6.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.446.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-drag-drop-files": "^3.0.1",
    "react-hook-form": "^7.53.2",
    "react-redux": "^9.1.2",
    "react-router-dom": "^7.10.1",
    "react-scripts": "5.0.1",
    "redux": "^5.0.1",
    "redux-saga": "^1.3.0",
    "styled-components": "^6.1.13",
    "web-vitals": "^2.1.0"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@babel/plugin-syntax-import-meta": "^7.10.4",
    "@babel/preset-env": "^7.28.6",
    "@babel/preset-react": "^7.28.5",
    "@eslint/js": "^8.57.0",
    "@stryker-mutator/core": "^9.4.0",
    "@stryker-mutator/jest-runner": "^9.4.0",
    "@swc/core": "^1.15.21",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "ajv": "^8.17.1",
    "autoprefixer": "^10.4.20",
    "babel-jest": "^30.2.0",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^28.9.0",
    "eslint-plugin-jsdoc": "^50.4.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.12",
    "eslint-plugin-redux-saga": "^1.3.2",
    "eslint-plugin-unused-imports": "^4.1.4",
    "glob": "^13.0.6",
    "globals": "^15.12.0",
    "husky": "^9.1.6",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^27.4.0",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "react-refresh": "^0.18.0",
    "tailwindcss": "^3.4.13",
    "whatwg-fetch": "^3.6.20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@swc/core", "core-js", "core-js-pure"]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
