# Default: same-origin /api (CRA dev server proxies to the Java API). Avoids CORS and localhost vs 127.0.0.1 mismatches.
# PROXY_TARGET is read by src/setupProxy.js (API origin only, no /api suffix). Override in .env.development.local if needed.
# For a direct API URL instead, set e.g. REACT_APP_API_BASE_URL=http://127.0.0.1:8000 in .env.development.local
REACT_APP_API_BASE_URL=
PROXY_TARGET=http://127.0.0.1:8000

# Match `npm run lint` when running the dev server (same as .env.production for builds).
EXTEND_ESLINT=true
