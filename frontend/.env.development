# CRA proxies /api (and /ws) to PROXY_TARGET — Java Spring Boot default (see src/setupProxy.js).
# Start only the Java API: cd backend-java && ./gradlew bootRun (listens on 127.0.0.1:8000).
# Do not run another backend on 8000 at the same time (e.g. Python uvicorn would conflict).
# Optional: override PROXY_TARGET if the API runs elsewhere. Leave REACT_APP_API_BASE_URL empty to use /api + proxy.
REACT_APP_API_BASE_URL=
PROXY_TARGET=http://127.0.0.1:8000

# Match `npm run lint` when running the dev server (same as .env.production for builds).
EXTEND_ESLINT=true
